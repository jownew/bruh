# Copy this file to .env.local and fill in real values (never commit .env.local)

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_...

# The "from" address — must be a verified domain or email in your Resend account
RESEND_FROM=Kids Quiz App <noreply@yourdomain.com>

# Where contact form submissions get delivered
CONTACT_TO=you@yourdomain.com
